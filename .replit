modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
VITE_FIREBASE_AUTH_DOMAIN = "crms-90bee.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "crms-90bee"
VITE_FIREBASE_STORAGE_BUCKET = "crms-90bee.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "146334942868"
VITE_FIREBASE_APP_ID = "1:146334942868:web:563d5393a43347f9a89681"
